<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MovieExplorer.MovieListPage"
             Title="Browse Movies">

    <Grid RowDefinitions="Auto,Auto,Auto,Auto,*">

        <!--Row 0: Search and filter-->
        <HorizontalStackLayout Grid.Row="0" Padding="15" Spacing="10">
            <Entry x:Name="SearchEntry" 
                   Placeholder="Search movies..."
                   WidthRequest="250"
                   TextChanged="OnSearchTextChanged"/>

            <Picker x:Name="GenrePicker"
                    Title="Filter by Genre"
                    WidthRequest="150"
                    SelectedIndexChanged="OnGenreChanged"/>
        </HorizontalStackLayout>

        <!--Row 1: Movie count label-->
        <Label Grid.Row="1"
               x:Name="MovieCountLabel"
               Text="Loading movies..."
               FontSize="14"
               HorizontalOptions="Center"
               Margin="0,0,0,10"/>

        <!--Row 2: Sort buttons-->
        <HorizontalStackLayout Grid.Row="2" Padding="10" Spacing="10" HorizontalOptions="Center">
            <Button Text="Sort by Title" 
                    CommandParameter="Title" 
                    Clicked="OnSortClicked"
                    BackgroundColor="#512BD4"
                    TextColor="White"/>
            <Button Text="Sort by Year" 
                    CommandParameter="Year" 
                    Clicked="OnSortClicked"
                    BackgroundColor="#512BD4"
                    TextColor="White"/>
            <Button Text="Sort by Rating" 
                    CommandParameter="Rating" 
                    Clicked="OnSortClicked"
                    BackgroundColor="#512BD4"
                    TextColor="White"/>
        </HorizontalStackLayout>

        <!--Row 3: Add Movie button-->
        <Button Grid.Row="3"
                Text="+ Add Movie"
                Clicked="OnAddMovieClicked"
                BackgroundColor="Green"
                TextColor="White"
                Margin="10,5"
                HeightRequest="40"/>

        <!--Row 4: Movie list - Takes remaining space and scrolls-->
        <CollectionView Grid.Row="4"
                        x:Name="MovieCollectionView"
                        ItemsSource="{Binding FilteredMovies}"
                        SelectionMode="Single"
                        SelectionChanged="OnMovieSelected">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Padding="15" 
                            Margin="10,5" 
                            StrokeThickness="1"
                            Stroke="LightGray"
                            BackgroundColor="White">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="10"/>
                        </Border.StrokeShape>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!--Movie Emoji-->
                            <Label Text="{Binding Emoji}" 
                                   FontSize="30"
                                   Grid.Column="0"
                                   VerticalOptions="Center"/>

                            <!--Movie Info-->
                            <VerticalStackLayout Grid.Column="1" 
                                                 Spacing="5"
                                                 Padding="15,0">

                                <Label Text="{Binding DisplayInfo}" 
                                       FontSize="18"
                                       TextColor="Black"
                                       FontAttributes="Bold"/>

                                <Label Text="{Binding GenreDisplay}" 
                                       FontSize="14"
                                       TextColor="Gray"/>

                                <Label Text="{Binding Director}" 
                                       FontSize="12"
                                       TextColor="DarkGray"/>
                            </VerticalStackLayout>

                            <!--Rating display-->
                            <Label Text="{Binding RatingDisplay}" 
                                   Grid.Column="2"
                                   FontSize="14"
                                   TextColor="Orange"
                                   VerticalOptions="Center"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>

</ContentPage>
